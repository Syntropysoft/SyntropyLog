{
  "name": "syntropylog-native",
  "version": "1.1.0",
  "description": "Native Rust addon for SyntropyLog (fast serialization + masking)",
  "main": "index.js",
  "module": "index.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.js",
      "types": "./index.d.ts"
    }
  },
  "napi": {
    "name": "syntropylog_native",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin",
      "aarch64-pc-windows-msvc",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "napi build --platform --release && node scripts/patch-index-no-shell.js",
    "build:debug": "napi build && node scripts/patch-index-no-shell.js",
    "test": "node test-node.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "2.18.4"
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "*.node"
  ]
}
